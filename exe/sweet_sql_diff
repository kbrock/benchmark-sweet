#!/usr/bin/env ruby
# frozen_string_literal: true

# Compare SQL output files generated by Benchmark::Sweet#save_sql
#
# Usage: sweet_sql_diff file1.sql file2.sql [file3.sql ...]
#
# Examples:
#   sweet_sql_diff read_bench-mp2-current.sql read_bench-mp3-current.sql

abort "Usage: sweet_sql_diff file1.sql file2.sql [file3.sql ...]" if ARGV.size < 2

def parse_sql_file(path)
  sections = {}
  header = []
  current_op = nil

  File.readlines(path).each do |line|
    line = line.rstrip
    if line.start_with?("#")
      header << line
    elsif (m = line.match(/^== (.+) ==$/))
      current_op = m[1]
      sections[current_op] = { sql: [], plan: [] }
    elsif current_op
      if line.start_with?("SQL:")
        sections[current_op][:sql] << line.sub(/^SQL: /, "")
      elsif line.start_with?("PLAN:")
        sections[current_op][:plan] << line.sub(/^PLAN: /, "")
      elsif line == "(no queries)"
        sections[current_op][:sql] << "(no queries)"
      end
    end
  end

  { header: header, sections: sections }
end

files = ARGV.map do |path|
  abort "File not found: #{path}" unless File.exist?(path)
  name = File.basename(path, ".sql")
  [name, parse_sql_file(path)]
end

all_ops = files.flat_map { |_, data| data[:sections].keys }.uniq

# Header
names = files.map(&:first)
puts "SQL Comparison: #{names.join(' vs ')}"
puts "=" * 60
puts ""

# Per-operation comparison
identical_count = 0
differ_count = 0

all_ops.each do |op|
  entries = files.map { |name, data| [name, data[:sections][op]] }
  sql_sets = entries.map { |_, section| section ? section[:sql] : [] }

  if sql_sets.uniq.size == 1
    identical_count += 1
    next  # skip identical operations in output
  end

  differ_count += 1
  puts "== #{op} == DIFFERS"
  entries.each do |name, section|
    next unless section
    section[:sql].each { |s| puts "  #{name}: #{s}" }
    section[:plan].each { |p| puts "  #{name} plan: #{p}" } if section[:plan].any?
  end
  puts ""
end

# Summary
puts "=" * 60
puts "Summary: #{identical_count} identical, #{differ_count} different out of #{all_ops.size} operations"
if differ_count == 0
  puts "All operations produce identical SQL across configs."
end
